# Variables de Entorno

# Copiar este archivo a ".env.local" y rellenar con tus valores
# NO COMMITEAR ESTE ARCHIVO A GIT EN LA RAMA PRINCIPAL

# Backend API
BACKEND_BASE_URL=http://localhost:3000/api
API_KEY=your_api_key_here

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pinterest_clone
DB_USER=postgres
DB_PASSWORD=your_password_here

# Firebase (si se usa para notificaciones)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_API_KEY=your_firebase_key

# JWT Token
JWT_SECRET=your_jwt_secret_key_here

# Configuración de Storage (para imagenes)
STORAGE_BUCKET=pinterest-clone-storage

# URLs de terceros
FACEBOOK_APP_ID=your_facebook_app_id
GOOGLE_API_KEY=your_google_api_key

# Configuración de email (si aplica)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
